<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>

        <!-- 1. API routes → Node FIRST, before anything else -->
        <rule name="API Routes" stopProcessing="true">
          <match url="^(api|appointments|auth|dashboard|queue).*" />
          <action type="Rewrite" url="server.js" />
        </rule>

        <!-- 2. Static files that actually exist in dist → serve them -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{DOCUMENT_ROOT}/dist/{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="dist/{R:1}" />
        </rule>

        <!-- 3. Everything else (SPA routes) → Node -->
        <rule name="DynamicContent">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>

      </rules>
    </rewrite>

    <security>
      <authorization>
        <add accessType="Allow" users="*" />
      </authorization>
    </security>
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>