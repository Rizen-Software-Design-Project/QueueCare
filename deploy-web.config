<configuration>
  <system.webServer>
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
      <add name="iisnode" path="servers/server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="NodeApp" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="servers/server.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode loggingEnabled="true"
             logDirectory="iisnode"
             watchedFiles="server.js;web.config;server/routes/appointmentRoutes.js" />
  </system.webServer>
</configuration>