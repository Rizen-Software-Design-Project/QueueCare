{
  "name": "community-clinic-appointment-and-queue-management-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://Rizen-Software-Design-Project.github.io/QueueCare",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd \"src/appointment booking\" && node servers/server.js",
    "start": "cd \"src/appointment booking\" && node servers/server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest run --coverage && cd \"src/appointment booking\" && npm test",
    "test:frontend": "vitest run --coverage",
    "test:backend": "cd \"src/appointment booking\" && npm test",
    "coverage": "vitest run --coverage",
    "test:authpage": "vitest run src/components/AuthPage.test.jsx",
    "test:dashboard": "vitest run src/components/Dashboard.test.jsx",
    "test:welcome": "vitest run src/components/Welcome.test.jsx",
    "test:clinicsearch": "vitest run src/components/Clinic_search.test.jsx"
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@supabase/supabase-js": "^2.103.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "resend": "^6.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.1.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.4"
  }
}
